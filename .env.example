# Backend database configuration for Aiven MySQL
MYSQLHOST=mysql-acdf045-sanvara.l.aivencloud.com
MYSQLPORT=10406
MYSQLDATABASE=defaultdb
MYSQLUSER=avnadmin
MYSQLPASSWORD=replace_with_your_aiven_password
MYSQL_SSL_MODE=REQUIRED

# Backend application configuration
SPRING_PROFILES_ACTIVE=prod
APP_SEED_ENABLED=true
APP_JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
APP_CORS_ALLOWED_ORIGINS=https://luminamart-frontend.onrender.com

# Frontend build configuration
VITE_API_BASE_URL=https://luminamart-backend.onrender.com
